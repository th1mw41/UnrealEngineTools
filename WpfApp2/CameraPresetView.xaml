<UserControl x:Class="WpfApp2.CameraPresetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Margin="10">
        <Label Content="Preset Name:" Foreground="White"/>

        <TextBox Text="{Binding PresetName, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="0,5" />

        <Button Content="Save Preset" 
                Command="{Binding SavePresetCommand}" 
                Padding="10,5" 
                Margin="0,10"/>
    </StackPanel>
</UserControl>