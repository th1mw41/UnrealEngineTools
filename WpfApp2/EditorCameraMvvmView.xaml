<UserControl x:Class="WpfApp2.EditorCameraMvvmView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#2D2D30">
    <StackPanel Margin="15">
        <TextBlock Text="MVVM Camera Preset" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Foreground="Gold"/>

        <TextBlock Text="Preset Name:" Margin="0,0,0,5"/>
        <TextBox Text="{Binding PresetName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15"/>
        <TextBlock Text="Saved Presets:" Margin="0,0,0,5" FontWeight="Bold"/>
        <Grid Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox ItemsSource="{Binding Presets}" 
              SelectedItem="{Binding SelectedPreset}" 
              Background="#2D2D30" 
              VerticalAlignment="Center"/>

            <Button Grid.Column="1" 
            Content="Delete" 
            Command="{Binding DeleteCommand}"
            Background="#442222" Foreground="White" 
            Padding="10,0" Margin="10,0,0,0" Height="28"/>
        </Grid>
        <TextBlock Text="Location (X, Y, Z)" FontWeight="SemiBold" Foreground="SkyBlue" Margin="0,0,0,5"/>
        <UniformGrid Columns="3" Margin="0,0,0,15">
            <StackPanel Margin="0,0,5,0">
                <TextBlock Text="X" FontSize="10" HorizontalAlignment="Center"/>
                <TextBox Text="{Binding X, StringFormat={}{0:F2}}" />
            </StackPanel>
            <StackPanel Margin="0,0,5,0">
                <TextBlock Text="Y" FontSize="10" HorizontalAlignment="Center"/>
                <TextBox Text="{Binding Y, StringFormat={}{0:F2}}" />
            </StackPanel>
            <StackPanel>
                <TextBlock Text="Z" FontSize="10" HorizontalAlignment="Center"/>
                <TextBox Text="{Binding Z, StringFormat={}{0:F2}}" />
            </StackPanel>
        </UniformGrid>

        <TextBlock Text="Rotation (Pitch, Yaw, Roll)" FontWeight="SemiBold" Foreground="LightCoral" Margin="0,0,0,5"/>
        <UniformGrid Columns="3" Margin="0,0,0,15">
            <StackPanel Margin="0,0,5,0">
                <TextBlock Text="P" FontSize="10" HorizontalAlignment="Center"/>
                <TextBox Text="{Binding Pitch, StringFormat={}{0:F2}}" />
            </StackPanel>
            <StackPanel Margin="0,0,5,0">
                <TextBlock Text="Y" FontSize="10" HorizontalAlignment="Center"/>
                <TextBox Text="{Binding Yaw, StringFormat={}{0:F2}}" />
            </StackPanel>
            <StackPanel>
                <TextBlock Text="R" FontSize="10" HorizontalAlignment="Center"/>
                <TextBox Text="{Binding Roll, StringFormat={}{0:F2}}" />
            </StackPanel>
        </UniformGrid>

        <UniformGrid Columns="3" Height="40" Margin="0,10,0,0">
            <Button Content="Fetch" 
            Command="{Binding FetchCommand}" 
            Background="DarkSlateGray" Foreground="White" Margin="0,0,2,0"/>

            <Button Content="Apply" 
            Command="{Binding ApplyCommand}" 
            Background="#FF0078D7" Foreground="White" Margin="2,0,2,0"/>

            <Button Content="Save" 
            Command="{Binding SaveCommand}" 
            Background="DarkGoldenrod" Foreground="White" Margin="2,0,0,0"/>
        </UniformGrid>
    </StackPanel>
</UserControl>