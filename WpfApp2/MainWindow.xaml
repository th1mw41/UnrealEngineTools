<Window x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2"
        mc:Ignorable="d"
        Title="Unreal Remote Control" Height="550" Width="850"
        Background="#1E1E1E">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D4D4D4"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D30"/>
<!--apparently for text inside the combo box-->
            <Setter Property="Foreground" Value="#2D2D30"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>

            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" 
                       VerticalAlignment="Center" 
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBoxItem}}"
                       FontWeight="{Binding FontWeight, RelativeSource={RelativeSource AncestorType=ComboBoxItem}}"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#2D2D30"/>
                        <!--text for rest combo box-->
                        <Setter Property="Foreground" Value="#D4D4D4"/>
                        <Setter Property="Padding" Value="5"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                                <!--text for hovering item in combo box highlight-->
                                <Setter Property="Foreground" Value="#007ACC"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                                <Setter Property="Foreground" Value="#2D2D30"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#3F3F46"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#505050"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Available Commands" Grid.Column="0" Margin="0,0,10,0" FontWeight="SemiBold">
                <ListBox x:Name="CommandListBox" 
                         DisplayMemberPath="Name" 
                         SelectionChanged="CommandListBox_SelectionChanged" 
                         FontSize="14" Padding="5" Margin="5"/>
            </GroupBox>

            <GroupBox Header="Properties &amp; Execution" Grid.Column="1" FontWeight="SemiBold">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <ContentControl x:Name="PropertyContainer"/>
                    </ScrollViewer>

                    <Button x:Name="ExecuteButton" Grid.Row="1" 
                            Content="Execute Selected Command" 
                            Click="ExecuteButton_Click" 
                            Height="40" Margin="0,15,0,0"
                            Background="#FF0078D7" Foreground="White" FontWeight="Bold" FontSize="14"/>
                </Grid>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="1" FontWeight="SemiBold">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="Console Output" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Button x:Name="ToggleConsoleBtn" Content="▼ Hide" Padding="10,2" FontWeight="Normal" Cursor="Hand" Click="ToggleConsoleBtn_Click"/>
                </StackPanel>
            </GroupBox.Header>

            <TextBox x:Name="ConsoleLog" Height="150"
             FontFamily="Consolas" FontSize="13"
             IsReadOnly="True" TextWrapping="Wrap" 
             VerticalScrollBarVisibility="Auto" Padding="5"/>
        </GroupBox>
    </Grid>
</Window>